{
	"$schema": "https://raw.githubusercontent.com/WordPress/wordpress-develop/trunk/src/wp-content/themes/flavor/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": false,
		"useRootPaddingAwareAlignments": true,
		"typography": {
			"fluid": true,
			"customFontSize": false,
			"dropCap": false,
			"fontFamilies": [
				{
					"slug": "system",
					"name": "System",
					"fontFamily": "system-ui, -apple-system, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif"
				}
			],
			"fontSizes": [
				{
					"slug": "small",
					"size": "clamp(0.875rem, 0.8rem + 0.4vw, 1rem)",
					"name": "Small",
					"fluid": false
				},
				{
					"slug": "medium",
					"size": "clamp(1rem, 0.95rem + 0.25vw, 1.125rem)",
					"name": "Medium",
					"fluid": false
				},
				{
					"slug": "large",
					"size": "clamp(1.125rem, 1rem + 0.6vw, 1.5rem)",
					"name": "Large",
					"fluid": false
				},
				{
					"slug": "x-large",
					"size": "clamp(1.5rem, 1.25rem + 1.25vw, 2rem)",
					"name": "X-Large",
					"fluid": false
				},
				{
					"slug": "xx-large",
					"size": "clamp(2rem, 1.5rem + 2.5vw, 3rem)",
					"name": "XX-Large",
					"fluid": false
				}
			]
		},
		"spacing": {
			"spacingSizes": [
				{
					"slug": "xs",
					"size": "clamp(0.25rem, 0.2rem + 0.25vw, 0.5rem)",
					"name": "XS"
				},
				{
					"slug": "sm",
					"size": "clamp(0.5rem, 0.4rem + 0.5vw, 1rem)",
					"name": "SM"
				},
				{
					"slug": "md",
					"size": "clamp(1rem, 0.75rem + 1.25vw, 2rem)",
					"name": "MD"
				},
				{
					"slug": "lg",
					"size": "clamp(2rem, 1.5rem + 2.5vw, 4rem)",
					"name": "LG"
				},
				{
					"slug": "xl",
					"size": "clamp(4rem, 3rem + 5vw, 8rem)",
					"name": "XL"
				}
			],
			"units": [
				"rem",
				"%"
			]
		},
		"color": {
			"custom": false,
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "text",
					"color": "#2f342d",
					"name": "Text"
				},
				{
					"slug": "background",
					"color": "#faf9f4",
					"name": "Background"
				},
				{
					"slug": "surface",
					"color": "#f4f4ee",
					"name": "Surface"
				},
				{
					"slug": "surface-alt",
					"color": "#ffffff",
					"name": "Surface Alt"
				},
				{
					"slug": "primary",
					"color": "#4c6547",
					"name": "Primary"
				},
				{
					"slug": "primary-dim",
					"color": "#41593c",
					"name": "Primary Dim"
				},
				{
					"slug": "border",
					"color": "#afb3aa",
					"name": "Border"
				},
				{
					"slug": "tertiary",
					"color": "#e5f4c9",
					"name": "Tertiary"
				},
				{
					"slug": "on-tertiary",
					"color": "#505d3c",
					"name": "On Tertiary"
				},
				{
					"slug": "on-surface-variant",
					"color": "#5c6058",
					"name": "On Surface Variant"
				}
			]
		},
		"layout": {
			"contentSize": "min(90vw, 1200px)",
			"wideSize": "min(95vw, 1400px)"
		},
		"blocks": {
			"core/paragraph": {
				"color": {
					"custom": false
				}
			},
			"core/heading": {
				"color": {
					"custom": false
				}
			},
			"core/group": {
				"color": {
					"custom": false
				}
			}
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--system)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.5"
		},
		"spacing": {
			"padding": {
				"top": "var(--wp--preset--spacing--md)",
				"right": "var(--wp--preset--spacing--sm)",
				"bottom": "var(--wp--preset--spacing--md)",
				"left": "var(--wp--preset--spacing--sm)"
			}
		},
		"color": {
			"background": "var(--wp--preset--color--background)",
			"text": "var(--wp--preset--color--text)"
		},
		"elements": {
			"link": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--text)"
					}
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--surface-alt)"
				},
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--primary-dim)",
						"text": "var(--wp--preset--color--surface-alt)"
					}
				}
			}
		}
	},
	"templateParts": [
		{
			"name": "header",
			"title": "Header",
			"area": "header"
		},
		{
			"name": "footer",
			"title": "Footer",
			"area": "footer"
		}
	]
}
